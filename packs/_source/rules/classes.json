      },
      "image": {},
      "text": {
        "format": 1,
        "content": "<table><caption>Classes Summary</caption><thead><tr><th>Class</th><th>Hit Die</th><th>Primary Ability</th><th>Saving Throw Proficiencies</th><th>Armor and Weapon Proficiencies</th></tr></thead><tbody><tr><td>@UUID[Compendium.materia-dnd.classes.Item.zoT4Ju0EekLFMOdr]{Artificer}</td><td>d8</td><td>Intelligence</td><td>Constitution &amp; Intelligence</td><td>Light and medium armor, shields, Simple weapon, firearms, hand crossbows, heavy crossbows</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.1CZknH7dQtZ5azTo]{Barbarian}</td><td>d12</td><td>Strength</td><td>Strength &amp; Constitution</td><td>Light and medium armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.LiolWbiMhzTCiNQR]{Bard}</td><td>d8</td><td>Charisma</td><td>Dexterity &amp; Charisma</td><td>Light armor, simple weapons, hand crossbows, longswords, rapiers, shortswords</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.kwaLZIVDpgfgPrKd]{Blood Hunter}</td><td>d8</td><td>Intelligence</td><td>Dexterity &amp; Intelligence</td><td>Light and medium armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.nBAoOSYxB9l59dDR]{Cleric}</td><td>d8</td><td>Wisdom</td><td>Wisdom &amp; Charisma</td><td>Light and medium armor, shields, simple weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.eiYVUiTzb3RP2g7r]{Druid}</td><td>d8</td><td>Wisdom</td><td>Intelligence &amp; Wisdom</td><td>Light and medium armor (nonmetal), shields (nonmetal), clubs, daggers, darts, javelins, maces, quarterstaffs, scimitars, sickles, slings, spears</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.nSISbeDTW2QoOrNJ]{Fighter}</td><td>d10</td><td>Strength or Dexterity</td><td>Strength &amp; Constitution</td><td>All armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.VETNJW8jypJHYOs7]{Monk}</td><td>d8</td><td>Dexterity &amp; Wisdom</td><td>Strength &amp; Dexterity</td><td>Simple weapons, shortswords</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.npLv9JK3XSu6fHQC]{Paladin}</td><td>d10</td><td>Strength &amp; Charisma</td><td>Wisdom &amp; Charisma</td><td>All armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.8hJ75TNiM2riJOh3]{Ranger}</td><td>d10</td><td>Dexterity &amp; Wisdom</td><td>Strength &amp; Dexterity</td><td>Light and medium armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.Gsnnf9BhcxLyir8L]{Rogue}</td><td>d8</td><td>Dexterity</td><td>Dexterity &amp; Intelligence</td><td>Light armor, simple weapons, hand crossbows, longswords, rapiers, shortswords</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.ryMgJTgrBtoa3ONI]{Sorcerer}</td><td>d6</td><td>Charisma</td><td>Constitution &amp; Charisma</td><td>Daggers, darts, slings, quarterstaffs, light crossbows</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.6ooHi0Tp2oEAwByq]{Warlock}</td><td>d8</td><td>Charisma</td><td>Wisdom &amp; Charisma</td><td>Light armor, simple weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.a95rTCTjwDDnV3PD]{Warlock (INT Variant)}</td><td>d8</td><td>Intelligence</td><td>Wisdom &amp; Intelligence</td><td>Light armor, simple weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.O0FAuLZvvFYV9bRb]{Warlord}</td><td>d10</td><td>Charisma</td><td>Wisdom &amp; Charisma</td><td>Light and medium armor, shields, simple and martial weapons</td></tr><tr><td>@UUID[Compendium.materia-dnd.classes.Item.dMnyTl1INQwa5JjI]{Wizard}</td><td>d6</td><td>Intelligence</td><td>Intelligence &amp; Wisdom</td><td>Daggers, darts, slings, quarterstaffs, light crossbows</td></tr></tbody></table>"
      },
